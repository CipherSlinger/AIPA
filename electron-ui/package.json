{
  "name": "claude-code-ui",
  "version": "1.1.148",
  "description": "Desktop UI for Claude Code CLI",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "vite-plugin-electron dev",
    "build": "npm run clear-prefs && npm run build:main && npm run build:clawd && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:clawd": "node -e \"const fs=require('fs'),path=require('path');const src=path.join(__dirname,'src/main/clawd'),dst=path.join(__dirname,'dist/main/clawd');function cp(s,d){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const sp=path.join(s,f),dp=path.join(d,f),st=fs.statSync(sp);if(st.isDirectory())cp(sp,dp);else fs.copyFileSync(sp,dp)}}cp(src,dst);console.log('copied clawd to dist/main/clawd')\"",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "check": "npm run typecheck && npm run lint",
    "clear-prefs": "node -e \"const p=require('path').join(require('os').homedir(),'AppData/Roaming/Electron/claude-code-ui-prefs.json');try{require('fs').unlinkSync(p);console.log('cleared prefs')}catch{}\"",
    "rebuild-pty": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-builder install-app-deps && electron-rebuild -f -w node-pty && node scripts/patch-node-pty.js && node scripts/verify-pty.js",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "audit": "npm audit --production --audit-level=high"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "^39.8.3",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "date-fns": "^4.1.0",
    "electron-store": "^8.2.0",
    "highlight.js": "^11.11.1",
    "htmlparser2": "^12.0.0",
    "koffi": "^2.15.2",
    "lucide-react": "^0.460.0",
    "node-pty": "^0.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  }
}
